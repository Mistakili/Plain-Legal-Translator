# DigitalOcean Gradient AI - Model Access Key
# Get yours at: https://cloud.digitalocean.com → AI & ML → Gradient AI
# Must be a Model Access Key, NOT a personal dop_v1_ token
DO_GRADIENT_API_KEY=your_gradient_ai_model_access_key_here

# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/plainlegal

# Session secret - any long random string
SESSION_SECRET=change_this_to_a_long_random_string
